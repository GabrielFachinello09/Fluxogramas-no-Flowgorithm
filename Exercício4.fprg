    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="numero" type="Real" array="False" size=""/>
            <output expression="&quot;Qual n&#250;mero voc&#234; escolheu?&quot;" newline="True"/>
            <input variable="numero"/>
            <if expression="numero &gt; 0">
                <then>
                    <output expression="&quot;Seu n&#250;mero &#233; positivo&quot;" newline="True"/>
                </then>
                <else>
                    <if expression="numero &lt; 0">
                        <then>
                            <output expression="&quot;Seu n&#250;mero &#233; negativo&quot;" newline="True"/>
                        </then>
                        <else>
                            <if expression="numero = 0">
                                <then>
                                    <output expression="&quot;Seu n&#250;mero &#233; nulo&quot;" newline="True"/>
                                </then>
                                <else/>
                            </if>
                        </else>
                    </if>
                </else>
            </if>
        </body>
    </function>
</flowgorithm>
